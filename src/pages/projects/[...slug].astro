---
import { getCollection, render } from "astro:content";
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Container from "../../ui/Container.astro";
import PageHeader from "../../ui/PageHeader.astro";

export async function getStaticPaths() {
	const projectEntries = await getCollection("projects");
	return projectEntries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ProjectLayout frontmatter={entry.data}>
	<section class="py-32">
		<Container>
			<div class="max-w-3xl mx-auto">
				<div class="mb-12">
					<PageHeader
						title={entry.data.title}
						subtitle={entry.data.description}
					/>
				</div>
				<div
					class="prose prose-invert prose-neutral max-w-none
          prose-headings:font-medium prose-headings:tracking-tight
          prose-h2:text-xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:text-heading
          prose-p:text-subtle prose-p:font-light prose-p:leading-relaxed prose-p:text-base
          prose-li:text-subtle prose-li:font-light
          prose-strong:text-heading prose-strong:font-medium
          prose-hr:border-line prose-hr:my-12
          prose-img:w-full prose-img:h-72 sm:prose-img:h-auto prose-img:object-cover prose-img:border prose-img:border-white/5 prose-img:rounded-sm"
				>
					<Content />
				</div>
			</div>
		</Container>
	</section>
</ProjectLayout>
