---
import Container from "../ui/Container.astro";
import PageHeader from "../ui/PageHeader.astro";

const reviews = [
	{
		platform: "Upwork",
		text: "Great experience working with Artem. Very strong attention to detail — he kept refining and adjusting everything until it was exactly right. Skilled, experienced, and easy to work with.",
		author: "Wilson Williams · Nigeria",
	},
	{
		platform: "Fiverr",
		text: "Artem K surpassed expectations with his impeccable attention to detail and code expertise, delivering a truly professional website. His polite and proactive communication made the collaboration smooth and efficient.",
		author: "Thomasaunora · Denmark",
	},
	{
		platform: "Freelancehunt",
		text: "Артем дуже якісно і раніше терміну виконав замовлення. Були враховані всі мої побажання. Дуже задоволена роботою і рекомендую!",
		author: "Олена Мартинюк · Ukraine",
	},
	{
		platform: "Freelancehunt",
		text: "Дуже швидко виконав роботу. Щиро вдячний!",
		author: "Андрій Синіцин · Ukraine",
	},
];
---

<section class="py-32">
  <Container>
    <PageHeader
      title="Відгуки"
      subtitle="Що кажуть клієнти про досвід співпраці"
    />

    <div class="grid md:grid-cols-2 gap-8">
      {
        reviews.map((review) => (
          <div class="p-8 border border-line bg-card transition-all duration-500 rounded-sm flex flex-col justify-between">
            <div>
              <div class="flex items-center justify-between mb-8">
                <span class="text-[10px] uppercase tracking-[0.2em] text-faint">
                  {review.platform}
                </span>
                <div class="flex gap-0.5">
                  {[...Array(5)].map(() => (
                    <span class="text-[10px] text-faded">★</span>
                  ))}
                </div>
              </div>

              <p class="text-base text-subtle leading-relaxed font-light ">
                "{review.text}"
              </p>
            </div>

            <div class="mt-8 pt-6 border-t border-line">
              <p class="text-[10px] uppercase tracking-[0.1em] text-faded">
                {review.author}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>