---
import Container from "../ui/Container.astro";
import WorldMap from "../components/WorldMap.astro";

const clients = [
	{ x: 1152, y: 195, label: "Ukraine" },
	{ x: 1048, y: 430, label: "Nigeria" },
	{ x: 1035, y: 148, label: "Denmark" },
];
---

<section id="map" class="py-20">
	<Container>
		<div class="max-w-2xl mb-12">
			<h2 class="text-4xl font-bold mb-6 text-text-main">Міжнародний досвід</h2>

			<p class="text-text-muted leading-relaxed">
				Реалізовані проєкти для клієнтів із {clients.length} країн світу.
			</p>
		</div>

		<div class="max-w-6xl mx-auto">
			<WorldMap markers={clients} />
		</div>
	</Container>
</section>
