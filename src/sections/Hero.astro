---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import ActionLink from "../ui/ActionLink.astro";
---

<section
  class="relative min-h-screen flex items-center overflow-hidden bg-hero"
>
  <Container class="relative z-10 w-full">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-7 text-center md:text-left pt-20">
        <h1
          class="text-5xl md:text-6xl font-light mb-8 text-heading leading-[1.1] tracking-tight"
        >
          Розробка сайтів <br />
          <span class="text-subtle">для вашого бізнесу</span>
        </h1>

        <p
          class="text-xl text-subtle mb-10 max-w-lg mx-auto md:mx-0 leading-relaxed font-light"
        >
          Лендинги, корпоративні сайти, калькулятори розрахунків та інші
          веб-рішення
        </p>

        <div
          class="flex flex-col sm:flex-row gap-6 justify-center md:justify-start items-center"
        >
          <Button href="#contact">Обговорити проєкт</Button>
          <ActionLink href="/projects" text="Мої роботи →" />
        </div>
      </div>
    </div>
  </Container>


  <div
    class="absolute inset-y-0 right-0 w-full md:w-[50%] z-0 pointer-events-none hero-video-mask overflow-hidden"
  >
    <video
      id="hero-video"
      autoplay
      loop
      muted
      playsinline
      class="w-full h-full object-cover opacity-30 md:opacity-40"
    >
      <source src="/videos/hero-video.mp4" type="video/mp4" />
    </video>

    <div
      class="absolute inset-0 hidden md:block bg-gradient-to-r from-hero via-hero/20 to-transparent"
    >
    </div>
  </div>
</section>

<style>
  .hero-video-mask {
    -webkit-mask-image: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.3) 0%,
      black 50%
    );
    mask-image: linear-gradient(to right, rgba(0, 0, 0, 0.3) 0%, black 50%);
  }

  @media (min-width: 768px) {
    .hero-video-mask {
      -webkit-mask-image: none;
      mask-image: none;
    }
  }
</style>
