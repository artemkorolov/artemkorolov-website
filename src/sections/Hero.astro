---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import SocialLinks from "../ui/SocialLinks.astro";
---

<section class="py-24 md:py-40 overflow-hidden">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-8 text-center md:text-left">
        <h1
          class="text-5xl md:text-7xl font-extrabold mb-8 text-text-main leading-tight tracking-tight"
        >
          Створюю професійні <span class="text-primary">вебрішення</span> для
          вашого бізнесу
        </h1>
        <p class="text-xl text-text-muted mb-10 max-w-2xl mx-auto md:mx-0">
          Від лендингів до складних вебзастосунків. Допомагаю малому бізнесу
          автоматизувати процеси та масштабуватися завдяки сучасним технологіям.
        </p>
        <div class="flex gap-4 justify-center md:justify-start">
          <Button href="#contact">Обговорити проєкт</Button>
          <a
            href="#projects"
            class="group inline-flex items-center gap-2 text-base font-medium text-text-main hover:text-primary transition-colors"
          >
            Мої роботи
            <span class="transition-transform group-hover:translate-x-1">→</span
            >
          </a>
        </div>
      </div>

      <div class="md:col-span-4 relative hidden md:block">
        <div
          class="aspect-3/4 rounded-2xl bg-surface border border-border relative overflow-hidden shadow-2xl group"
        >
          <div
            class="absolute inset-0 bg-linear-to-t from-background/90 via-background/20 to-transparent z-10"
          >
          </div>

          <img
            src="./src/assets/artem-korolov.png"
            alt="Артем Корольов - Веб-розробник"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />

          <div class="absolute bottom-0 left-0 p-6 z-20 w-full">
            <p class="text-white font-bold text-lg">Артем Корольов</p>
            <p class="text-primary font-medium text-sm mb-4">
              Fullstack Розробник
            </p>

           <SocialLinks/>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
