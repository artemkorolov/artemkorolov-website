---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <main class="max-w-4xl mx-auto px-6 py-12 md:py-20">
    <article class="prose prose-lg prose-blue dark:prose-invert mx-auto">
      <header class="mb-12">
        <h1 class="text-4xl md:text-5xl font-extrabold text-text-main mb-4">
          {frontmatter.title}
        </h1>
        <p class="text-text-muted italic">{frontmatter.date}</p>

        {
          frontmatter.tech && (
            <ul class="flex flex-wrap gap-2 mt-6 not-prose">
              {frontmatter.tech.map((tag: string) => (
                <li class="bg-bg-surface border border-border px-3 py-1 rounded-md text-sm text-text-muted">
                  {tag}
                </li>
              ))}
            </ul>
          )
        }
      </header>

      <div class="content">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>
