---
import "../styles/global.css";

interface Props {
	title: string;
	description: string;
}

const {
	title = "Artem Korolov | Web Developer",
	description = "Modern websites and web applications built with Astro, React and TypeScript",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
