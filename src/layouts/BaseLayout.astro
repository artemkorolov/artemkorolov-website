---
import Header from "../partials/Header.astro";
import "../styles/global.css";

interface Props {
	title: string;
	description: string;
}

const {
	title = "Артем Корольов | Веб-розробка для бізнесу",
	description = "Сучасна розробка сайтів та застосунків",
} = Astro.props;
---

<!doctype html>
<html lang="uk">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
	</body>
</html>
