---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link: string;
  image: string;
}

const { title, description, tags, link, image } = Astro.props;
---

<a
  href={link}
  class="group block border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-all duration-500 rounded-sm overflow-hidden"
>
  <div class="aspect-[16/10] overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 brightness-75 group-hover:brightness-100"
    />
  </div>

  <div class="p-8">
    <h3
      class="text-sm font-medium text-white mb-2 group-hover:text-white transition-colors"
    >
      {title}
    </h3>
    <p class="text-xs text-white/40 leading-relaxed mb-6 font-light">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 pt-4 border-t border-white/5">
      {
        tags.map((tag: string) => (
          <span class="text-[10px] uppercase tracking-widest text-white/20 border border-white/5 px-2 py-0.5 rounded-sm">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</a>
