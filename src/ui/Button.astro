---
interface Props {
	href: string;
	variant?: "primary" | "secondary";
}

const { href, variant = "primary" } = Astro.props;

const styles = {
	primary: "bg-primary text-white hover:opacity-90",
	secondary: "border border-border text-text hover:bg-bg-base",
};
---

<a
	href={href}
	class:list={[
		"rounded-md px-5 py-3 text-sm font-medium transition-opacity",
		variant === "primary" &&
			"bg-primary text-white hover:opacity-90",
		variant === "secondary" &&
			"border border-border hover:bg-bg-base",
	]}
>
	<slot />
</a>
