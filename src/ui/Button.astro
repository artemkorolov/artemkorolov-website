---
interface Props {
	href: string;
	variant?: "primary" | "secondary";
}

const { href, variant = "primary" } = Astro.props;
---

<a
	href={href}
	class:list={[
		"inline-flex items-center justify-center rounded-sm px-6 py-3 text-[10px] uppercase tracking-[0.2em] transition-all duration-300",

		variant === "primary" && "bg-btn text-text-btn hover:bg-btn/90",

		variant === "secondary" &&
			"border border-line text-text-muted hover:border-white/40 hover:text-white",
	]}
>
	<slot />
</a>
