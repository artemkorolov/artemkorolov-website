---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<div class={`flex gap-4 ${className || ""}`}>
	<!-- Telegram -->
	<a
		href="https://t.me/..."
		target="_blank"
		class="text-white/70 hover:text-white transition-colors"
	>
		<span class="sr-only">Telegram</span>
		<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
			><path
				d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.56 8.12l-1.85 8.71c-.13.59-.49.73-.99.45l-2.73-2.01-1.32 1.27c-.15.15-.27.27-.55.27l.2-2.88 5.25-4.74c.23-.2-.05-.31-.35-.11l-6.5 4.09-2.81-.88c-.61-.19-.62-.61.13-.9l10.9-4.2c.5-.19.95.12.78.89z"
			></path></svg
		>
	</a>

