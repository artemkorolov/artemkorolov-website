---
interface Props {
	href?: string;
	text?: string;
	class?: string;
}

const {
	href = "/contact",
	text = "Всі контакти та деталі →",
	class: className = "",
} = Astro.props;
---

<a
	href={href}
	class={`inline-block text-[10px] uppercase tracking-[0.2em] text-subtle hover:text-white transition-colors duration-300 border-b border-white/10 pb-1 hover:border-white/50 ${className}`}
>
	{text}
</a>
