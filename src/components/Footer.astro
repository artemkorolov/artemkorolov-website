---
import Container from "../ui/Container.astro";
import NavLinks from "../ui/NavLinks.astro";
import SocialLinks from "../ui/SocialLinks.astro";

const currentYear = new Date().getFullYear();
---

<footer class="py-12 border-t border-line bg-hero mt-auto">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
      <div class="flex flex-col items-center md:items-start justify-center gap-1.5 text-center md:text-left">
        <p class="text-subtle text-sm">
          © {currentYear} Artem Korolov.
        </p>
        <a href="/privacy" class="text-xs text-subtle hover:text-suble/70 transition-colors underline">
          Політика конфіденційності
        </a>
      </div>

      <nav class="flex justify-center gap-6 text-sm text-white/60">
        <NavLinks />
      </nav>

      <div class="flex justify-center md:justify-end">
        <SocialLinks />
      </div>
    </div>
  </Container>
</footer>
